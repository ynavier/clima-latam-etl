# Copia este archivo como .env y completa los valores
# NUNCA subas .env a GitHub

# GCP
GCP_PROJECT_ID=tu-project-id
ENVIRONMENT=local

# BigQuery datasets
BQ_DATASET_RAW=weather_raw
BQ_DATASET_CLEAN=weather_clean
BQ_DATASET_MART=weather_mart

# Pipeline
PIPELINE_MAX_RETRIES=3
API_REQUEST_TIMEOUT=30

# Credenciales (solo desarrollo local)
# En producción usa: gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
